# --- Algorand Connection ---
# MNEMONIC: Your 25-word secret key (Required)
MNEMONIC="your seed phrase here..."

# ALPHA_API_KEY: Discovery API Key (Required)
ALPHA_API_KEY="your_api_key_here"

# Optional: Override default mainnet nodes
# ALGOD_SERVER="https://mainnet-api.algonode.cloud"
# INDEXER_SERVER="https://mainnet-idx.algonode.cloud"

# --- Bot Configuration ---
# Target Market Application ID (Optional if passed via CLI)
TARGET_MARKET_ID=3078581851

# Default Order Size in USDC (Optional if passed via CLI)
ORDER_SIZE_USDC=50

# Custom Bot ID for tracking
# BOT_ID="MyBot-Main"

# --- Safety & Strategy ---
# Distance from midpoint to place orders (cents). Default: 1.5
SAFETY_BUFFER_CENTS=1.5

# seconds between price checks. Default: 30
TICK_INTERVAL=30

# Number of ticks to wait before liquidation begins. Default: 2
LIQUIDATION_WINDOW_TICKS=2

# Maximum loss per share (cents) before market exit. Static at 5.0 in code.
